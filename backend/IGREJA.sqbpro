ional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE admins (
	id INTEGER PRIMARY KEY AUTOINCREMENT,
	
	nome TEXT NOT NULL,
	email TEXT NOT NULL UNIQUE,
	senha_hash TEXT NOT NULL,
	
	role TEXT CHECK (
		role IN ('PASTOR', 'ADMIN', 'SECRETARIA', 'LIDER')
	) NOT NULL,
	
	ativo TEXT CHECK(ativo IN ('SIM', 'NAO')) NOT NULL DEFAULT 'SIM',
	
	congregacao TEXT,
	setor TEXT,
	
	created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
	last_login DATETIME
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
